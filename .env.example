ANTHROPIC_API_KEY=sk-ant-...
# Optional — raises GitHub API rate limits for fetch_github_repo (MCP + Ask AI tools)
GITHUB_TOKEN=
# Optional — enables Spotify Premium full-track playback (PKCE, no secret needed)
# Create an app at https://developer.spotify.com/dashboard
# Settings → Redirect URIs must include the URL below (port must match your dev server).
# Local dev: http://localhost:3000/spotify-callback  (or :3002 if 3000 is taken)
# Production: https://your-domain.com/spotify-callback
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
# Optional — pin redirect URI if your dev port varies (must match Spotify dashboard exactly)
# NEXT_PUBLIC_SPOTIFY_REDIRECT_URI=http://localhost:3002/spotify-callback


